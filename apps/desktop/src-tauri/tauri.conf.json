{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Annotated",
  "version": "0.1.0",
  "identifier": "com.annotated.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3091",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Annotated",
        "width": 1180,
        "height": 820,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
