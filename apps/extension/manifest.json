{
  "manifest_version": 3,
  "name": "Annotated \u2014 Clip & Comment",
  "version": "0.1.0",
  "description": "Clip articles, videos, and podcasts. Add your take. Share to annotated.com.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://annotated-nwhitcraft.fly.dev/*",
    "http://localhost:3080/*",
    "http://127.0.0.1:3080/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Annotated"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "description": "Open Annotated sidebar"
    },
    "start_clipping": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Alt+Shift+X"
      },
      "description": "Start Annotated clipping mode"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
