{
  "name": "annotated",
  "version": "0.1.0",
  "private": true,
  "description": "Annotated — Cross-platform media clipper & commentary feed",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=packages/api",
    "build:extension": "npm run build --workspace=apps/extension",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "tauri:desktop": "npm run tauri:dev --workspace=apps/desktop"
  },
  "engines": {
    "node": ">=20"
  }
}
